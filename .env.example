# Copiar este archivo a .env.local y poner los valores reales.
# .env.local está en .gitignore: nunca se commitea.
#
# Estas variables van a Project Settings de Vercel cuando despliegues.
# Ambas son NEXT_PUBLIC_ porque viajan al bundle del cliente. Eso está bien:
# el acceso real a los datos lo gobiernan las policies RLS en Supabase.
#
# Lo que NUNCA va aquí ni en el repo es la service_role key.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica
